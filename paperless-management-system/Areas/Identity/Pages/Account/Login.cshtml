@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="d-flex flex-column flex-root">
    <!--begin::Login-->
    <div class="login login-3 login-signin-on d-flex flex-row-fluid">
        <div class="d-flex flex-center bgi-size-cover bgi-no-repeat flex-row-fluid" style="background-image: url('@Url.Content("~/assets/media/bg/wd-bg.jpg")');">
            <div class="login-form text-center text-white p-7 position-relative overflow-hidden">
                <!--begin::Login Header-->
                <div class="d-flex flex-center mb-15">
                    <img src="~/assets/media/logos/wd-2.png" class="max-h-100px" alt="" />
@*                    <img src="~/assets/media/logos/sophic.png" class="max-h-100px" alt="" />*@
                </div>
                <!--end::Login Header-->
                <!--begin::Login Sign in form-->
                <div class="login-signin">
                    <div class="mb-10">
                        <h2>e-Record (v 1.0.0.4)</h2>
                        <p class="opacity-70 font-weight-bold">Enter your details to login to your account:</p>
                    </div>
                    <form class="form" id="account" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-group">
                            <input asp-for="Input.UserName" class="form-control h-auto text-white placeholder-white opacity-70 bg-white-o-20 rounded-pill border-0 py-4 px-8 mb-5" placeholder="User Id (Employee Id)" autocomplete="off" />
@*                            <span asp-validation-for="Input.Email" class="text-danger"></span>*@
                        </div>
                        <div class="form-group">
                            <input asp-for="Input.Password" class="form-control h-auto text-white placeholder-white opacity-70 bg-white-o-20 rounded-pill border-0 py-4 px-8 mb-5" placeholder="Password" autocomplete="off" />
@*                            <span asp-validation-for="Input.Password" class="text-danger"></span>*@
                        </div>
                        <div class="form-group text-center mt-10">
                            <button class="btn btn-pill btn-outline-white font-weight-bold opacity-90 px-15 py-3" type="submit">Sign In</button>
                        </div>
                    </form>
                </div>
                <!--end::Login Sign in form-->
            </div>
        </div>
    </div>
    <!--end::Login-->
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
