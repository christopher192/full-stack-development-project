@page
@model WD_ERECORD_CORE.Pages.eRecord.eFormSelectionModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "My e-Record";
}

<!--begin::Main-->
<!--begin::Header Mobile-->
<partial name="_PartialMobileHeader" />
<!--end::Header Mobile-->
<!--begin::Page-->
<!--begin::Aside-->
@await Component.InvokeAsync("Aside", new { current = "erecord" })
<!--end::Aside-->
<!--begin::Wrapper-->
<div class="d-flex flex-column flex-row-fluid wrapper" id="kt_wrapper">
    <!--begin::Header-->
    @await Component.InvokeAsync("Header", new { current = "My e-Record" })
    <!--end::Header-->
    <!--begin::Content-->
    <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
        <!--begin::Subheader-->
        <!--end::Subheader-->
        <!--begin::Entry-->
        <div class="d-flex flex-column-fluid">
            <!--begin::Container-->
            <div class="container-fluid">
                <!--begin::Form Management List-->
                <div class="card card-custom card-stretch">
                    <!--begin::Header-->
                    <div class="card-header">
                        <div class="card-title">@ViewData["CostCenter"]</div>
                    </div>
                    <!--end::Header-->
                    <!--begin::Body-->
                    <div class="card-body">
                        <form class="mb-15">
                            <div class="row mb-6">
                                <div class="col-lg-6 mb-lg-0 mb-6">
                                    <label>Master Form Name:</label>
                                    <input type="text" class="form-control datatable-input" placeholder="E.g: eXX-X-XX-XX-XXXXX" data-col-index="0" />
                                </div>
                                <div class="col-lg-6 mb-lg-0 mb-6">
                                    <label>Master Form Description:</label>
                                    <input type="text" class="form-control datatable-input" placeholder="E.g: For Production" data-col-index="1" />
                                </div>
                            </div>
                            <div class="row mt-8">
                                <div class="col-lg-12">
                                    <button class="btn btn-primary btn-primary--icon" id="kt_search">
                                        <span>
                                            <i class="la la-search"></i>
                                            <span>Search</span>
                                        </span>
                                    </button>&#160;&#160;
                                    <button class="btn btn-secondary btn-secondary--icon" id="kt_reset">
                                        <span>
                                            <i class="la la-close"></i>
                                            <span>Reset</span>
                                        </span>
                                    </button>
                                </div>
                            </div>
                        </form>
                        <!--begin: Datatable-->
                        <table class="table table-bordered table-hover table-checkable" id="selectform_datatable" style="margin-top: 13px !important">
                            <thead>
                                <tr>

                                    <th>Form Name</th>
                                    <th>Form Description</th>
                                    <th>Revision</th>
                                    <th>Action</th>

                                </tr>
                            </thead>
                        </table>
                        <!--end: Datatable-->
                    </div>
                    <div class="card-footer">
                        <div class="float-left">
                            <a class="btn btn-secondary" asp-page="Index">Cancel</a>
                        </div>
                    </div>
                    <!--end::Body-->
                </div>
                <!--end::Form Management List-->
                <!--end::Dashboard-->
            </div>
            <!--end::Container-->
        </div>
        <!--end::Entry-->
    </div>
    <!--end::Content-->
    <!--begin::Footer-->
    <partial name="_Footer" />
    <!--end::Footer-->
</div>
<!--end::Wrapper-->
<!--end::Page-->
<!--end::Main-->

<script src="~/assets/plugins/global/plugins.bundle.js"></script>
<script src="~/assets/js/scripts.bundle.js"></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/assets/plugins/custom/datatables/datatables.bundle.js"></script>

<script type="text/javascript">
    var FormAdvancedSearch = function () {
        var initFormTable = function () {
            var table = $("#selectform_datatable").DataTable({
                stateSave: true,
                processing: true,
                serverSide: true,
                paging: true,
                responsive: true,
                searching: { regex: true },
                lengthMenu: [10, 25, 50, 100, 500, 1000, 2500, 5000],
                dom: `<'row'<'col-sm-12'tr>>
                        <'row'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 dataTables_pager'lp>>`,
                language: {
                    'lengthMenu': 'Display _MENU_',
                },
                // Ajax Filter
                ajax: {
                    url: "@Url.Action("LoadMasterFormSelectionTable", "DataTable")",
                    type: "POST",
                    contentType: "application/json",
                    dataType: "json",
                    data: function (d) {
                        return JSON.stringify(d);
                    }
                },
                // Columns Setups
                columns: [
                    { data: "masterFormName" },
                    { data: "masterFormDescription" },
                    { data: "masterFormRevision" },
                    { data: null, responsivePriority: -1 }
                ],
                columnDefs: [
                    {
                        targets: 1,
                        render: function (data, type, full, meta) {
                            return data !== null ? data : "Not Available";
                        },
                    },
                    {
                        targets: 2,
                        render: function (data, type, full, meta) {
                            return 'Rev ' + data;
                        },
                    },
                    {
                        targets: -1,
                        orderable: false,
                        data: null,
                        render: function (data, type, full, meta) {
                            return '<a class="btn btn-sm btn-primary" title="Select Form" href="@Url.Action("Create", "eRecord")/' + full.id + '/eFormSelection">Select</a>';
                        }
                    }
                ]
            });

            $('#kt_search').on('click', function (e) {
                e.preventDefault();
                var params = {};
                $('.datatable-input').each(function () {
                    var i = $(this).data('col-index');
                    if (params[i]) {
                        params[i] += '|' + $(this).val();
                    }
                    else {
                        params[i] = $(this).val();
                    }
                });
                $.each(params, function (i, val) {
                    table.column(i).search(val ? val : '', false, false);
                });
                table.table().draw();
            });

            $('#kt_reset').on('click', function (e) {
                e.preventDefault();
                $('.datatable-input').each(function () {
                    $(this).val('');
                    table.column($(this).data('col-index')).search('', false, false);
                });
                table.column(8).search('', false, false);
                table.table().draw();
            });
        };

        return {
            init: function () {
                initFormTable();
            }
        };
    }();

    jQuery(document).ready(function () {
        FormAdvancedSearch.init();
    });
</script>
