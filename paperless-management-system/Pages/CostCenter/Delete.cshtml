@page
@model WD_ERECORD_CORE.Pages.CostCenter.DeleteModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Cost Center Management";
}

<!--begin::Main-->
<!--begin::Header Mobile-->
<partial name="_PartialMobileHeader" />
<!--end::Header Mobile-->
<!--begin::Page-->
<!--begin::Aside-->
@await Component.InvokeAsync("Aside", new { current = "department" })
<!--end::Aside-->
<!--begin::Wrapper-->
<div class="d-flex flex-column flex-row-fluid wrapper" id="kt_wrapper">
    <!--begin::Header-->
    @await Component.InvokeAsync("Header", new { current = "Cost Center Management" })
    <!--end::Header-->
    <!--begin::Content-->
    <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
        <!--begin::Subheader-->
        <!--end::Subheader-->
        <!--begin::Entry-->
        <div class="d-flex flex-column-fluid">
            <!--begin::Container-->
            <div class="container-fluid">
                <!--begin::Form Management List-->
                <div class="card card-custom card-stretch">
                    <!--begin::Header-->
                    <div class="card-header">
                        <div class="card-title">
                            Delete Cost Center
                        </div>
                        <div class="card-toolbar">

                        </div>
                    </div>
                    <!--end::Header-->
                    <!--begin::Body-->
                    <div class="card-body">
                        <!--begin::Notice-->
                        <div class="row">
                            <div class="col-lg-9 col-xl-6 offset-xl-3">
                                <div class="alert alert-custom alert-outline-2x alert-outline-danger fade show mb-5" role="alert">
                                    <div class="alert-icon"><i class="flaticon-warning"></i></div>
                                    <div class="alert-text">Are you sure want to delete this?</div>
                                </div>
                            </div>
                        </div>
                        <!--end::Notice-->
                        <div class="form-group row">
                            <div class="col-xl-6">
                                <label asp-for="CostCenterList.Code" class="control-label"></label>
                                <input asp-for="CostCenterList.Code" class="form-control" disabled />
                                <span asp-validation-for="CostCenterList.Code" class="text-danger"></span>
                            </div>
                            <div class="col-xl-6">
                                <label asp-for="CostCenterList.Name" class="control-label"></label>
                                <input asp-for="CostCenterList.Name" class="form-control" disabled />
                                <span asp-validation-for="CostCenterList.Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-xl-6">
                                <label asp-for="CostCenterList.JobTitle" class="control-label"></label>
                                <input asp-for="CostCenterList.JobTitle" class="form-control" disabled />
                                <span asp-validation-for="CostCenterList.JobTitle" class="text-danger"></span>
                            </div>
                            <div class="col-xl-6">
                                <label asp-for="CostCenterList.JobClassificationTrack" class="control-label"></label>
                                <input asp-for="CostCenterList.JobClassificationTrack" class="form-control" disabled />
                                <span asp-validation-for="CostCenterList.JobClassificationTrack" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <form method="post">
                        <div class="card-footer">
                            <input type="hidden" asp-for="CostCenterList.Id" />
                            <a asp-page="Index" class="btn btn-light">Back</a>
                            <input type="submit" value="Delete" class="btn btn-danger" />
                        </div>
                    </form>
                    <!--end::Body-->
                </div>
                <!--end::Form Management List-->
                <!--end::Dashboard-->
            </div>
            <!--end::Container-->
        </div>
        <!--end::Entry-->
    </div>
    <!--end::Content-->
    <!--begin::Footer-->
    <partial name="_Footer" />
    <!--end::Footer-->
</div>
<!--end::Wrapper-->
<!--end::Page-->
<!--end::Main-->
