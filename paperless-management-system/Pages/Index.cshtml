                                                        <h1 class="centered">@ann.Label1</h1>
                                                        <h1 class="centered2">@ann.Label2</h1>
                                                        <img src="data:image/png;base64,@ann.Image" style="height:275px;" />
                                                    </div>
                                                </div>
                                            }
                                            else
