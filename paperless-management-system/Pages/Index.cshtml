                                                    <div class="row">
                                                        <div class="col">
                                                            <div class="d-flex justify-content-center align-items-center" style="height:270px;">
                                                                <div>
                                                                    <h1 class="text-center">@ann.Label1</h1>
                                                                    <div class="text-center mt-5">
                                                                        <h1>@ann.Label2</h1>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
