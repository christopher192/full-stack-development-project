                                        <span class="text-muted">@Model.dvm.User.ManagerId</span>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span class="font-weight-bold mr-2">Supervisor Name:</span>
                                        <span class="text-muted">@Model.dvm.User.ManagerName</span>
                                    </div>
                                </div>
                                <!--end::Contact-->
                            </div>
                        </div>
                        <!--end::Card-->
                    </div>
                    <div class="col-xxl-8 col-xl-8 col-md-6 col-sm-6">
                        <div class="card card-custom gutter-b card-stretch">
                            <div class="card-body">

                                @if (Model.dvm.Announcement.Count != 0)
                                {
                                    <div class="owl-carousel owl-theme">
                                        @foreach (var ann in Model.dvm.Announcement)
                                        {
                                            if (ann.Image != null)
                                            {
                                                <div class="item">
