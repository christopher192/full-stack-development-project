                                        <a href="#" class="font-weight-bolder font-size-h5 text-dark-75 text-hover-primary">@Model.dvm.User.DisplayName<i class="flaticon2-correct text-success icon-md ml-2"></i></a>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between mb-2">
