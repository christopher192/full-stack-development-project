<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/assets/plugins/custom/owlcarousel/owl.carousel.min.js"></script>

<script type="text/javascript">
    var ApexChart = function () {
        var _initAnnualSubmission = function () {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index", "")?handler=AnnualSubmission',
                headers: { "RequestVerificationToken": "@token" },
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    $("#annualLoading").css("display", "none");
                    $("#annualSubmissionData").css("display", "");

                    var element = document.getElementById("AnnualAnnouncementSubmission");

                    if (!element) {
                        return;
                    }

                    var annualSubmissionData = data;

                    if (data.length > 0) {
                        var options = {
                            series: annualSubmissionData,
                            chart: {
                                type: 'line',
                                height: 350,
                                toolbar: {
                                    show: false
                                }
                            },
                            plotOptions: {

                            },
                            title: {
                                text: 'Annual Submission',
                                align: 'left'
                            },
                            legend: {
                                show: false
                            },
                            dataLabels: {
                                enabled: false
                            },
                            xaxis: {
                                categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
                            },
                            yaxis: {
                                labels: {
                                    formatter: function (value) {
                                        return Math.floor(value)
                                    }
                                },
                                min: 0
                            }
                        };

                        var chart = new ApexCharts(element, options);
                        chart.render();                    
                    }
                    else
                    {
                        var html = '<div class="d-flex justify-content-center align-items-center" style="height:270px;"><h1>No Annual Submission</h1></div>';
                        $("#AnnualAnnouncementSubmission").html(html);
                    }
                }
            });
        }

        var _initDailySubmission = function () {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index", "")?handler=DailySubmission',
                headers: { "RequestVerificationToken": "@token" },
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    $("#dailyLoading").css("display", "none");
                    $("#dailySubmissionData").css("display", "");

                    var element = document.getElementById("DailyAnnouncementSubmission");

                    if (!element) {
                        return;
                    }

                    var dailySubmissionData = data;

                    if (dailySubmissionData.length > 0) {
                        var labels = [];
                        var series = [];

                        for (var i = 0; i < dailySubmissionData.length; i++) {
                            labels.push(dailySubmissionData[i].Labels);
                            series.push(dailySubmissionData[i].Series);
                        }

                        var options = {
                            series: series,
                            chart: {
                                width: '100%',
                                height: 400,
                                type: 'pie',
                            },
                            labels: labels,
                            title: {
                                text: 'Today Submission',
                                align: 'left',
                            },
                            legend: {
                                show: false
                            },
                            responsive: [{
                                breakpoint: 480,
                                options: {
                                    chart: {
                                        width: 200
                                    },
                                    legend: {
                                        position: 'bottom'
                                    }
                                }
                            }],
                            dataLabels: {
                                formatter(val, opts) {
                                    const name = opts.w.globals.labels[opts.seriesIndex]
                                    return [name, opts.w.config.series[opts.seriesIndex]]
                                }
                            },
                        };

                        var chart = new ApexCharts(element, options);
                        chart.render();
                    }
                    else {
                        var html = '<div class="d-flex justify-content-center align-items-center" style="height:270px;"><h1>No Daily Submission</h1></div>';
                        $("#DailyAnnouncementSubmission").html(html);
                    }
                }
            });
        }

        var _initWeeklySubmission = function () {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index", "")?handler=WeeklySubmission',
                headers: { "RequestVerificationToken": "@token" },
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    $("#weeklyLoading").css("display", "none");
                    $("#weeklySubmissionData").css("display", "");

                    var element = document.getElementById("WeeklyAnnouncementSubmission");

                    if (!element) {
                        return;
                    }

                    var weeklySubmissionData = data;
                    var labels = [];
                    var series = [];

                    if (weeklySubmissionData.length > 0) {
                        for (var i = 0; i < weeklySubmissionData.length; i++) {
                            labels.push(weeklySubmissionData[i].Labels);
                            series.push(weeklySubmissionData[i].Series);
                        }

                        var options = {
                            series: series,
                            chart: {
                                width: '100%',
                                height: 400,
                                type: 'pie',
                            },
                            labels: labels,
                            title: {
                                text: 'Weekly Submission',
                                align: 'left',
                            },
                            legend: {
                                show: false
                            },
                            responsive: [{
                                breakpoint: 480,
                                options: {
                                    chart: {
                                        width: 200
                                    },
                                    legend: {
                                        position: 'bottom'
                                    }
                                }
                            }],
                            dataLabels: {
                                formatter(val, opts) {
                                    const name = opts.w.globals.labels[opts.seriesIndex]
                                    return [name, opts.w.config.series[opts.seriesIndex]]
                                }
                            },
                        };

                        var chart = new ApexCharts(element, options);
                        chart.render();                                        
                    } 
                    else {
                        var html = '<div class="d-flex justify-content-center align-items-center" style="height:270px;"><h1>No Weekly Submission</h1></div>';
                        $("#WeeklyAnnouncementSubmission").html(html);
                    }
                }
            });
        }

        var _initMonthlySubmission = function () {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index", "")?handler=MonthlySubmission',
                headers: { "RequestVerificationToken": "@token" },
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    $("#monthlyLoading").css("display", "none");
                    $("#monthlySubmissionData").css("display", "");

                    var element = document.getElementById("MonthlyAnnouncementSubmission");

                    if (!element) {
                        return;
                    }

                    var monthlySubmissionData = data;
                    var labels = [];
                    var series = [];

                    if (monthlySubmissionData.length > 0) {
                        for (var i = 0; i < monthlySubmissionData.length; i++) {
                            labels.push(monthlySubmissionData[i].Labels);
                            series.push(monthlySubmissionData[i].Series);
                        }

                        var options = {
                            series: series,
                            chart: {
                                width: '100%',
                                height: 400,
                                type: 'pie',
                            },
                            labels: labels,
                            title: {
                                text: 'Monthly Submission',
                                align: 'left',
                            },
                            legend: {
                                show: false
                            },
                            responsive: [{
                                breakpoint: 480,
                                options: {
                                    chart: {
                                        width: 200
                                    },
                                    legend: {
                                        position: 'bottom'
                                    }
                                }
                            }],
                            dataLabels: {
                                formatter(val, opts) {
                                    const name = opts.w.globals.labels[opts.seriesIndex]
                                    return [name, opts.w.config.series[opts.seriesIndex]]
                                }
                            },
                        };

                        var chart = new ApexCharts(element, options);
                        chart.render();
                    } 
                    else {
                        var html = '<div class="d-flex justify-content-center align-items-center" style="height:270px;"><h1>No Monthly Submission</h1></div>';
                        $("#MonthlyAnnouncementSubmission").html(html);
                    }
                }
            });
        }

        return {
            init: function () {
                _initDailySubmission();
                _initWeeklySubmission();
                _initMonthlySubmission();
                _initAnnualSubmission();
            }
        }
    }();

    var Dashboard = function () {
        var calendarData = '@Json.Serialize(ViewData["CalendarData"])';
        var parseCalendarData = JSON.parse(calendarData);

        var Calendar = function () {
            var todayDate = moment().startOf('day');
            var YM = todayDate.format('YYYY-MM');
            var YESTERDAY = todayDate.clone().subtract(1, 'day').format('YYYY-MM-DD');
            var TODAY = todayDate.format('YYYY-MM-DD');
            var TOMORROW = todayDate.clone().add(1, 'day').format('YYYY-MM-DD');

            var calendarEl = document.getElementById('kt_calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                plugins: ['bootstrap', 'interaction', 'dayGrid', 'timeGrid', 'list'],
                themeSystem: 'bootstrap',

                isRTL: KTUtil.isRTL(),

                header: {
                    left: 'prev,next today btn-sm',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },

                height: 300,
                contentHeight: 380,
                aspectRatio: 3,  // see: https://fullcalendar.io/docs/aspectRatio

                nowIndicator: true,
                now: TODAY + 'T09:25:00', // just for demo

                views: {
                    dayGridMonth: { buttonText: 'month' },
                    timeGridWeek: { buttonText: 'week' },
                    timeGridDay: { buttonText: 'day' }
                },

                defaultView: 'dayGridMonth',
                defaultDate: TODAY,

                editable: true,
                eventLimit: true, // allow "more" link when too many events
                navLinks: true,
                events: parseCalendarData,

                eventRender: function (info) {
                    var element = $(info.el);

                    if (info.event.extendedProps && info.event.extendedProps.description) {
                        if (element.hasClass('fc-day-grid-event')) {
                            element.data('content', info.event.extendedProps.description);
                            element.data('placement', 'top');
                            KTApp.initPopover(element);
                        } else if (element.hasClass('fc-time-grid-event')) {
                            element.find('.fc-title').append('<div class="fc-description">' + info.event.extendedProps.description + '</div>');
                        } else if (element.find('.fc-list-item-title').lenght !== 0) {
                            element.find('.fc-list-item-title').append('<div class="fc-description">' + info.event.extendedProps.description + '</div>');
                        }
                    }
                }
            });

            calendar.render();
        }

        var PendingList = function () {
            // initial
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index", "")?handler=AcquireFormList',
                headers: { "RequestVerificationToken": "@token" },
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    $("#pendingLoading").css("display", "none");
                    $("#pendingList").css("display", "");
                    
                    var html = '';

                    if (data.length > 0)
                    {
                        for (let i = 0; i < data.length; i++) {
                            html += '<div class="d-flex align-items-center mb-6">';
                            html += '<div class="d-flex flex-column flex-grow-1 py-2">';
                            html += '<a href="@Url.Action("Index", "eRecord")/' + data[i].id + '" class="text-dark-75 font-weight-bold text-hover-primary font-size-lg mb-1">' + data[i].formName + '</a>';
                            html += '</div>';

                            if (data[i].formStatus === "pending") {
                                html += '<span class="label label-lg label-light-warning label-inline font-weight-bold py-4">Pending</span>';
                            }
