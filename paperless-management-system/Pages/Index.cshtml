@page
@model IndexModel
@inject IAntiforgery antiforgery

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";

    var token = antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<style>
    .fc-button {
        font-size: 12px !important;
        padding: 0px 4px !important;
        height: 27px !important;
    }

    .fc-center h2 {
        font-size: 14px !important;
    }

    .centered {
        position: absolute;
        top: 70%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .centered2 {
        position: absolute;
        top: 85%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .spinner.spinner-modified {
        right: 7.5%;
        bottom: 7.5%;
    }

    .spinner.spinner-modified:before {
        width: 4rem;
        height: 4rem;
    }
</style>

<!--begin::Main-->
<!--begin::Header Mobile-->
<partial name="_PartialMobileHeader" />
<!--end::Header Mobile-->
<!--begin::Page-->
<!--begin::Aside-->
@await Component.InvokeAsync("Aside", new { current = "dashboard" })
<!--end::Aside-->
<!--begin::Wrapper-->
<div class="d-flex flex-column flex-row-fluid wrapper" id="kt_wrapper">
    <!--begin::Header-->
    @await Component.InvokeAsync("Header", new { current = "Dashboard" })
    <!--end::Header-->
    <!--begin::Content-->
    <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
        <!--begin::Subheader-->
        <!--end::Subheader-->
        <!--begin::Entry-->
        <div class="d-flex flex-column-fluid">
            <!--begin::Container-->
            <div class="container-fluid">
                <!--begin::Dashboard-->
                <!--begin::Row-->
                <div class="row">
                    <div class="col-xxl-4 col-xl-4 col-md-6 col-sm-6">
                        <!--begin::Card-->
                        <div class="card card-custom gutter-b card-stretch">
                            <div class="card-body">
                                <!--begin::User-->
                                <div class="d-flex">
                                    @if (!String.IsNullOrEmpty(Model.dvm.User.ProfilePicture))
                                    {
                                        <div class="symbol symbol-50 symbol-lg-150 mr-5">
                                            <img src="data:image/png;base64,@Model.dvm.User.ProfilePicture" alt="Profile Picture">
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="symbol symbol-150 symbol-xxl-150 mr-5 align-self-start align-self-xxl-center">
                                            <div class="symbol-label" style="background-image: url('@Url.Content("~/assets/media/users/blank.png")');"></div>
                                        </div>
                                    }
                                </div>
                                <!--end::User-->
                                <!--begin::Separator-->
                                <div class="separator separator-solid my-7"></div>
                                <!--end::Separator-->
                                <!--begin::Contact-->
