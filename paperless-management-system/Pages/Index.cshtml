                                            <span class="card-icon">
                                                <i class="flaticon-list-3 text-primary"></i>
											</span>
                                            <h3 class="card-label font-weight-bolder text-dark">
                                                To-do List
                                                <small id="currentPendingList">(eRecord)</small>
                                            </h3>
                                        </div>
                                        <div class="card-toolbar">
                                            <div class="dropdown dropdown-inline">
                                                <button type="button" class="btn btn-light-primary btn-sm font-weight-bold dropdown-toggle" id="currentPendingListBtn" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    eRecord
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-sm dropdown-menu-right">
                                                    <!--begin::Navigation-->
                                                    <ul class="navi navi-hover">
                                                        <li class="navi-item">
                                                            <a href="javascript:;" class="navi-link" id="eRecordPendingListTrigger">
																<span class="navi-text">eRecord</span>
															</a>
                                                        </li>
                                                        <li class="navi-item">
															<a href="javascript:;" class="navi-link" id="FormApprovalPendingListTrigger">
																<span class="navi-text">Form Approval</span>
															</a>
                                                        </li>
                                                        <li class="navi-item">
