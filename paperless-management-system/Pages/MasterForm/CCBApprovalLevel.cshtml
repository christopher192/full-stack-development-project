@page "{DepartmentId?}"
@model WD_ERECORD_CORE.Pages.MasterForm.CCBApprovalLevelModel

@{
    ViewData["Title"] = "CCB Approval Level";
    Layout = "_FormBuilderLayout";
}

<!--begin::Wizard Nav-->
@if (Model.FormMode == "Create")
{
    @await Component.InvokeAsync("CreateEditWizardHeader", new { current = new string[] { "create", "5" } })
}
else if (Model.FormMode == "Edit")
{
    @await Component.InvokeAsync("CreateEditWizardHeader", new { current = new string[] { "edit", "5" } })
}
else if (Model.FormMode == "EditOnly")
{
    @await Component.InvokeAsync("EditApprovalOnlyHeader", new { current = new string[] { "edit", "4" } })
}
<!--end::Wizard Nav-->

<!--begin::Wizard Body-->
<div class="row">
    <div class="col-12 pt-3">
        <!--begin::Wizard Form-->
        <form class="px-2" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="FormMode" />
            <input type="hidden" asp-for="DepartmentId" />
            <input type="hidden" asp-for="MasterFormId" />

            <div class="form-group">
                <div class="d-flex justify-content-end">
                    <input type="submit" class="btn btn-primary" asp-page-handler="CreateApprovalLevel" value="Create Approval Level" />
                </div>
            </div>


            @if (Model.MasterFormCCBApprovalLevels.Count() > 0)
            {
                for (int i = 0; i < Model.MasterFormCCBApprovalLevels.Count(); i++)
                {
                    // bind this list
                    <input type="hidden" asp-for="MasterFormCCBApprovalLevels[i].Id" />

                    <div class="form-row">
                        <div class="col-12 form-group">
                            <h4>Approval Level @(i + 1)</h4>
                        </div>
                        <div class="col-12 form-group">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th scope="col">No</th>
                                        <th scope="col">Approver Name</th>
                                        <th scope="col">Approver Email</th>
                                        <th scope="col">Employee Id</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var formApprovers = Model.MasterFormCCBApprovers.Where(x => x.MasterFormCCBApprovalLevelId == Model.MasterFormCCBApprovalLevels[i].Id).OrderBy(x => x.Id).ToList();
                                    }

                                    @if (formApprovers.Count() > 0)
                                    {
                                        for (int x = 0; x < formApprovers.Count(); x++)
                                        {
                                            <tr>
                                                <th scope="row">@(x + 1)</th>
                                                <td>@formApprovers[x].ApproverName</td>
                                                <td>@formApprovers[x].ApproverEmail</td>
                                                <td>@formApprovers[x].EmployeeId</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" style="text-align: center;padding: 100px; font-weight: 600;">No Approver Yet</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="col-12 form-group">
                            <div class="d-flex justify-content-end">
                                <input type="submit" class="btn btn-primary" asp-page-handler="EditCCBApprovalLevel" asp-route-CCBApprovalLevelId="@Model.MasterFormCCBApprovalLevels[i].Id" value="Edit" />
                                <input type="submit" class="btn btn-danger ml-1" asp-page-handler="DeleteCCBApprovalLevel" asp-route-CCBApprovalLevelId="@Model.MasterFormCCBApprovalLevels[i].Id" value="Delete" />
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="form-group">
                    <div class="border d-flex align-items-center justify-content-center" style="height: 450px;">
                        <h1>No Approval Yet</h1>
                    </div>
                </div>
            }

            @{
                // bind these lists
                for (int i = 0; i < Model.MasterFormCCBApprovers.Count(); i++)
                {
                    <input type="hidden" asp-for="MasterFormCCBApprovers[i].Id" />
                    <input type="hidden" asp-for="MasterFormCCBApprovers[i].ApproverName" />
                    <input type="hidden" asp-for="MasterFormCCBApprovers[i].ApproverEmail" />
                    <input type="hidden" asp-for="MasterFormCCBApprovers[i].EmployeeId" />
                    <input type="hidden" asp-for="MasterFormCCBApprovers[i].MasterFormCCBApprovalLevelId" />
                }
            }

            <div class="form-group border-top mt-1">
                <div class="d-flex justify-content-end mt-3">
                    <div>
                        <input type="submit" class="btn btn-primary" asp-page-handler="Submit" value="Submit" />
                    </div>
                </div>
            </div>
        </form>
        <!--end::Wizard Form-->
    </div>
</div>
<!--begin::Wizard Body-->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
