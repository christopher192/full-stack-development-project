@page "{RequestFormMode?}/{Id?}"
@model WD_ERECORD_CORE.Pages.MasterForm.NumbericBuilderModel

@{
    ViewData["Title"] = "Numberic Builder";
    Layout = "_FormBuilderLayout";
}

<!--begin::Wizard Nav-->
@if (Model.FormMode == "Create") 
{
    @await Component.InvokeAsync("CreateEditWizardHeader", new { current = new string[] { "create", "1" } })
} 
else if (Model.FormMode == "Edit") 
{
    @await Component.InvokeAsync("CreateEditWizardHeader", new { current = new string[] { "edit", "1" } })
}
else if (Model.FormMode == "EditOnly")
{
    @await Component.InvokeAsync("EditApprovalOnlyHeader", new { current = new string[] { "edit", "1" } })
}
<!--end::Wizard Nav-->

<!--begin::Wizard Body-->
<div class="row">
    <div class="col-12 pt-3">
        <!--begin::Wizard Form-->
        <form method="post" class="px-2" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="FormMode" class="form-control" type="hidden" />
            <input asp-for="AllowEditNumbericScheme" class="form-control" type="hidden" />
            <input asp-for="MasterFormData" class="form-control" type="hidden" />
            <input asp-for="isPrevious" class="form-control" type="hidden" />
            <input asp-for="numbericBuilderViewModel.MasterFormId" class="form-control" type="hidden" />

            @if (Model.AllowEditNumbericScheme) {
                <div class="form-row">
                    <div class="form-group col-6">
                        <label class="form-label text-right">Department</label>
                        <select class="form-control select2" asp-for="numbericBuilderViewModel.DepartmentCode"></select>
                        <span asp-validation-for="numbericBuilderViewModel.DepartmentCode" class="text-danger"></span>
                    </div>
                    <div class="form-group col-6">
                        <label class="form-label text-right">Sub Department</label>
                        <select class="form-control select2" asp-for="numbericBuilderViewModel.SubDepartmentCode"></select>
                        <span asp-validation-for="numbericBuilderViewModel.SubDepartmentCode" class="text-danger"></span>                       
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-6">
                        <label class="form-label text-right">Factory</label>
                        <select class="form-control select2" asp-for="numbericBuilderViewModel.FactoryCode"></select>
                        <span asp-validation-for="numbericBuilderViewModel.FactoryCode" class="text-danger"></span>
                    </div>
                    <div class="form-group col-6">
                        <label class="form-label text-right">Document Category</label>
                        <select class="form-control select2" asp-for="numbericBuilderViewModel.DocumentCategoryCode"></select>
                        <span asp-validation-for="numbericBuilderViewModel.DocumentCategoryCode" class="text-danger"></span>                  
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-6">
                        <label class="form-label text-right">Form Description</label>
                        <input class="form-control" asp-for="numbericBuilderViewModel.MasterFormDescription" />
                        <span asp-validation-for="numbericBuilderViewModel.MasterFormDescription" class="text-danger"></span>
                    </div>
                    <div class="form-group col-6">
                        <label class="form-label text-right">Upload File</label>
                        <input class="form-control" asp-for="numbericBuilderViewModel.UploadFile" />
                        <span asp-validation-for="numbericBuilderViewModel.UploadFile" class="text-danger"></span>
                    </div>
                </div>
            }
            else
            {
                <input asp-for="numbericBuilderViewModel.DepartmentCode" class="form-control" type="hidden" />
                <input asp-for="numbericBuilderViewModel.SubDepartmentCode" class="form-control" type="hidden" />
                <input asp-for="numbericBuilderViewModel.FactoryCode" class="form-control" type="hidden" />
                <input asp-for="numbericBuilderViewModel.DocumentCategoryCode" class="form-control" type="hidden" />
                <input asp-for="numbericBuilderViewModel.GuidelineFile" class="form-control" type="hidden" />
                <input asp-for="numbericBuilderViewModel.UniqueGuidelineFile" class="form-control" type="hidden" />

                <div class="form-group form-row">
                    <div class="form-group col-6">
                        <label class="form-label text-right">Department</label>
                        <input class="form-control" asp-for="numbericBuilderViewModel.DepartmentCode" disabled />
                        <span asp-validation-for="numbericBuilderViewModel.DepartmentCode" class="text-danger"></span>
                    </div>
                    <div class="form-group col-6">
                        <label class="form-label text-right">Sub Department</label>
                        <input class="form-control" asp-for="numbericBuilderViewModel.SubDepartmentCode" disabled />
                        <span asp-validation-for="numbericBuilderViewModel.SubDepartmentCode" class="text-danger"></span>                       
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-6">
                        <label class="form-label text-right">Factory</label>
                        <input class="form-control" asp-for="numbericBuilderViewModel.FactoryCode" disabled />
                        <span asp-validation-for="numbericBuilderViewModel.FactoryCode" class="text-danger"></span>
                    </div>
                    <div class="form-group col-6">
                        <label class="form-label text-right">Document Category</label>
                        <input class="form-control" asp-for="numbericBuilderViewModel.DocumentCategoryCode" disabled />
                        <span asp-validation-for="numbericBuilderViewModel.DocumentCategoryCode" class="text-danger"></span>                  
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label text-right">Form Description</label>
                    <input class="form-control" asp-for="numbericBuilderViewModel.MasterFormDescription" />
                    <span asp-validation-for="numbericBuilderViewModel.MasterFormDescription" class="text-danger"></span>
                </div>
                @if (Model.numbericBuilderViewModel.GuidelineFile != null)
                {
                    <div class="form-group">
                        <label class="form-label text-right">Current User Manual</label>
                        <br />
                        <a class="inline-block" href="~/GuidelineFiles/@Model.numbericBuilderViewModel.UniqueGuidelineFile" target="_blank">
                            <img width="25" src="~/assets/media/svg/files/pdf.svg" /> @Model.numbericBuilderViewModel.GuidelineFile
                        </a>
                    </div>
                }
                <div class="form-group">
                    <label class="form-label text-right">Upload File</label>
                    <input class="form-control" asp-for="numbericBuilderViewModel.UploadFile" />
                    <span asp-validation-for="numbericBuilderViewModel.UploadFile" class="text-danger"></span>
                </div>
            }

            <div class="form-group border-top mt-5">
                <div class="d-flex justify-content-end mt-3">
                    <div>
                        <input asp-page-handler="Save" class="btn btn-primary" type="submit" value="Save" />
                        <input asp-page-handler="Next" class="btn btn-primary" type="submit" value="Next" />
                    </div>
                </div>
            </div>
        </form>
        <!--end::Wizard Form-->
    </div>
</div>
<!--end::Wizard Body-->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script type='text/javascript'>
    $(document).ready(function () {
        // match class, id and tagname for precise selection
        $('select.select2#numbericBuilderViewModel_DepartmentCode').select2({
            placeholder: "Select Department",
            allowClear: true,
            blurOnChange: true,
            openOnEnter: false,
            ajax: {
                url: "@Url.Action("GetDepartmentLists", "api")",
                dataType: 'json',
                data: function (params) {
                    return {
                        departmentName: params.term
                    };
                },
                processResults: function (data, page) {
                    return { results: data };
                },
                cache: true
            },
            error: function () {
                alert('Failed');
            },
            formatResult: function (data) {
                return "<div class='select2-user-result'>" + data.client + "</div>";
            },
            formatSelection: function (data) {
                return data.client;
            },
            templateSelection: function (data, container) {
                if (data.value === undefined) {
                    return "Select Department";
                }
                return data.value;
            }
        });

        $("select.select2#numbericBuilderViewModel_SubDepartmentCode").select2({
            placeholder: "Select Sub Department",
            allowClear: true,
            blurOnChange: true,
            openOnEnter: false,
            ajax: {
                url: "@Url.Action("GetSubDepartmentLists", "api")",
                dataType: 'json',
                data: function (params) {
                    return {
                        subDepartmentName: params.term
                    };
                },
                processResults: function (data, page) {
                    return { results: data };
                }
            },
            error: function () {
                alert('Failed');
            },
            formatResult: function (data) {
                return "<div class='select2-user-result'>" + data.client + "</div>";
            },
            formatSelection: function (data) {
                return data.client;
            },
            templateSelection: function (data, container) {
                if (data.value === undefined) {
                    return "Select Sub Department";
                }
                return data.value;
            }
        });

        $('select.select2#numbericBuilderViewModel_FactoryCode').select2({
            placeholder: "Select Factory",
            allowClear: true,
            blurOnChange: true,
            openOnEnter: false,
            ajax: {
                url: "@Url.Action("GetFactoryLists", "api")",
                dataType: 'json',
                data: function (params) {
                    return {
                        factoryName: params.term
                    };
                },
                processResults: function (data, page) {
                    return { results: data };
                }
            },
            error: function () {
                alert('Failed');
            },
            formatResult: function (data) {
                return "<div class='select2-user-result'>" + data.client + "</div>";
            },
            formatSelection: function (data) {
                return data.client;
            },
            templateSelection: function (data, container) {
                if (data.value === undefined) {
                    return "Select Factory";
                }
                return data.value;
            }
        });

        $('select.select2#numbericBuilderViewModel_DocumentCategoryCode').select2({
            placeholder: "Select Document Category",
            allowClear: true,
            blurOnChange: true,
            openOnEnter: false,
            ajax: {
                url: "@Url.Action("GetDocumentCategoryLists", "api")",
                dataType: 'json',
                data: function (params) {
                    return {
                        documentCategoryName: params.term
                    };
                },
                processResults: function (data, page) {
                    return { results: data };
                }
            },
            error: function () {
                alert('Failed');
            },
            formatResult: function (data) {
                return "<div class='select2-user-result'>" + data.client + "</div>";
            },
            formatSelection: function (data) {
                return data.client;
            },
            templateSelection: function (data, container) {
                if (data.value === undefined) {
                    return "Select Document Category";
                }
                return data.value;
            }
        });

        $('select.select2#numbericBuilderViewModel_DepartmentCode').on('select2:select', function (e) {
            var departmentData = e.params.data;
            $("select.select2#numbericBuilderViewModel_SubDepartmentCode").val(null).trigger('change');
            $("select.select2#numbericBuilderViewModel_SubDepartmentCode").prop("disabled", false).select2({
                placeholder: "Select Sub Department",
                allowClear: true,
                blurOnChange: true,
                openOnEnter: false,
                ajax: {
                    url: "@Url.Action("GetSubDepartmentLists", "api")",
                    dataType: 'json',
                    data: function (params) {
                        return {
                            departmentCode: departmentData.value,
                            subDepartmentName: params.term
                        };
                    },
                    processResults: function (data, page) {
                        return { results: data };
                    }
                },
                error: function () {
                    alert('Failed');
                },
                formatResult: function (data) {
                    return "<div class='select2-user-result'>" + data.client + "</div>";
                },
                formatSelection: function (data) {
                    return data.client;
                },
                templateSelection: function (data, container) {
                    if (data.value === undefined) {
                        return "Select Sub Department";
                    }
                    return data.value;
                }
            });
        }).on("select2:unselecting", function (e) {
            $("select.select2#numbericBuilderViewModel_SubDepartmentCode").prop("disabled", true).val(null).trigger('change');
        });
    });

    function refreshAndClose() {
        parent.document.location.href = "@Url.Action("Index", "MasterForm")";
        window.opener.location.reload(true);
        window.close();
    }

    var CloseWindowValue = '@TempData["Save"]';

    if (CloseWindowValue !== null && CloseWindowValue !== '') {
        refreshAndClose();
    }
</script>
