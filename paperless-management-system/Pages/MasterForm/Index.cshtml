                                var WriteHtml = "";

                                if (full.masterFormStatus === "active") {
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="View details" href="@Url.Action("Details", "MasterForm")/' + full.id + '"><i class="la la-eye"></i></a>';
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="Edit master form" href="javascript:windowEditOnlyPopUp(' + full.id + ');"><i class="la la-edit"></i></a>';
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="Duplicate master form" id="TriggerDuplicateTemplateModel" href="javascript:;"><i class="la la-plus-circle"></i></a>';

                                    return WriteHtml;
                                }
                                else if (full.masterFormStatus === "inactive") {
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="View details" href="@Url.Action("Details", "MasterForm")/' + full.id + '"><i class="la la-eye"></i></a>';

                                    return WriteHtml;
                                }
                                else if (full.masterFormStatus === "editing") {
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="View details" href="@Url.Action("Details", "MasterForm")/' + full.id + '"><i class="la la-eye"></i></a>';

                                    if (full.editor !== null && full.editor === currentUser) {
                                        WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="Edit master form" href="javascript:windowEditPopUp(' + full.id + ');"><i class="la la-edit"></i></a>';
                                    } else if (full.editor === null) {
                                        WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="Edit master form" href="javascript:windowEditPopUp(' + full.id + ');"><i class="la la-edit"></i></a>';
                                    }

                                    return WriteHtml;
                                }
                                else if (full.masterFormStatus === "pending") {
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="View details" href="@Url.Action("Details", "MasterForm")/' + full.id + '"><i class="la la-eye"></i></a>';

                                    return WriteHtml;
                                }
                                else if (full.formMasterStatus === "rejected") {
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="View details" href="@Url.Action("Details", "MasterForm")/' + full.id + '"><i class="la la-eye"></i></a>';
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="Edit master form" href="javascript:windowEditPopUp(' + full.id + ');"><i class="la la-edit"></i></a>';
                                    WriteHtml += '<a class="btn btn-sm btn-clean btn-icon" title="Delete master form" href="@Url.Action("Delete", "MasterForm")/' + full.id + '"><i class="la la-trash"></i></a>';

                                    return WriteHtml;
                                }
                            }
                        }
                    }
                ]
            });

            function refreshDataTable() {
                table.ajax.reload();
            }

            table.on('click', 'a#TriggerChangeLogModel', function () {
                var data = (typeof table.row(this).data() !== "undefined" ? table.row(this).data() : table.row($(this).parents('tr')).data());

                var split = data.changeLog.split(/-(.+)/);
                var removeWhiteSpace = split.map(x => x.trim());
                // Remove last array element
                removeWhiteSpace.pop();

                var writeHTML = "";
                var changeLogData = removeWhiteSpace;

                $("#ChangeLogData").empty();

                var description = [];
                var time = [];

                for (var i = 1; i <= changeLogData.length; i++) {
                    if ((i % 2) === 0) {
                        description.push(changeLogData[i - 1]);
                    }
                }

                for (var i = 1; i <= changeLogData.length; i++) {
                    if ((i % 2) === 1) {
                        time.push(changeLogData[i - 1]);
                    }
                }

                var newChangeLogData = [];

                if (description.length === time.length) {
                    for (var i = 0; i < description.length; i++) {
                        newChangeLogData.push(description[i]);
                        newChangeLogData.push(time[i]);
                    }
                }

                for (var i = 0; i < newChangeLogData.length; i++) {

                    if ((i % 2) === 1) {
                        writeHTML += "<span class='text-muted text-right'>" + newChangeLogData[i] + "</span>";
                        writeHTML += "</div>";
                        writeHTML += "</div>";
                    }
                    else {
                        writeHTML += "<div class='timeline-item'>";
                        writeHTML += "<div class='timeline-badge bg-primary'></div>";
                        writeHTML += "<div class='timeline-content d-flex align-items-center justify-content-between'>";
